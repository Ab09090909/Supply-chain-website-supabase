# =====================================================
# AI Supply Chain Platform — Environment Variables
# =====================================================
# Copy this file to `.env` and fill in your own values.
#
#   cp .env.example .env
#
# Get your Supabase keys from:
#   https://supabase.com/dashboard → Project → Settings → API
#
# Get your Groq key from:
#   https://console.groq.com/keys
#
# NEVER commit `.env` to git. It is in `.gitignore` for that reason.
# =====================================================

# Supabase project URL (no trailing slash)
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Supabase anon / public key (starts with "eyJ...")
SUPABASE_ANON_KEY=eyJ-replace-with-your-anon-key

# Supabase service_role key (starts with "eyJ...") — KEEP SECRET.
# Required for admin operations (user management, fraud review).
SUPABASE_SERVICE_ROLE_KEY=eyJ-replace-with-your-service-role-key

# Groq API key for the AI Assistant (starts with "gsk_...")
# Get one at https://console.groq.com/keys (free tier is fine)
GROQ_API_KEY=gsk-replace-with-your-groq-key

# Public URL of this app (used in password-reset email links)
APP_URL=http://localhost:8501
